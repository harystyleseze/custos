{
  "name": "custos",
  "version": "0.1.0",
  "description": "Privacy-native document intelligence on Fhenix — encrypted document sharing with AI analysis",
  "scripts": {
    "test": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' REPORT_GAS=true hardhat test",
    "compile": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' hardhat compile",
    "clean": "rimraf ./artifacts ./cache ./coverage ./types ./coverage.json",
    "eth-sepolia:deploy": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' hardhat deploy-vault --network eth-sepolia",
    "eth-sepolia:verify": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' hardhat verify --network eth-sepolia",
    "dev": "next dev",
    "build": "next build",
    "start": "next start"
  },
  "ts-node": {
    "project": "tsconfig.hardhat.json",
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  },
  "devDependencies": {
    "@cofhe/hardhat-plugin": "^0.4.0",
    "@cofhe/mock-contracts": "^0.4.0",
    "@fhenixprotocol/cofhe-contracts": "^0.1.3",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/mocha": ">=9.1.0",
    "@types/node": ">=18.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "chai": "^4.2.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.4.0",
    "hardhat": "^2.22.19",
    "hardhat-gas-reporter": "^1.0.8",
    "rimraf": "^5.0.0",
    "solidity-coverage": "^0.8.0",
    "ts-node": ">=8.0.0",
    "typechain": "^8.3.0",
    "typescript": "~5.7.0"
  },
  "dependencies": {
    "@cofhe/sdk": "^0.4.0",
    "@mlc-ai/web-llm": "^0.2.82",
    "@openzeppelin/contracts": "^5.0.0",
    "@rainbow-me/rainbowkit": "^2.2.0",
    "@tanstack/react-query": "^5.0.0",
    "@xenova/transformers": "^2.17.2",
    "next": "^14.2.0",
    "pinata": "^1.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "viem": "^2.17.0",
    "wagmi": "^2.12.0"
  }
}
